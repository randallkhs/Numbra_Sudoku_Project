rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    function isValidUserSettings(data) {
      return data.keys().hasOnly(['theme', 'soundEnabled', 'hapticsEnabled', 'hapticIntensity', 'stats']) &&
             data.theme is string && data.theme.size() <= 60 &&
             data.soundEnabled is bool &&
             data.hapticsEnabled is bool &&
             (!data.keys().hasAny(['hapticIntensity']) || data.hapticIntensity in ['low', 'medium', 'high']);
    }

    match /users/{userId}/settings/{docId} {
      allow read: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUserSettings(incoming());
      allow update: if isOwner(userId) && isValidId(userId) && isValidUserSettings(incoming());
      allow delete: if isOwner(userId) && isValidId(userId);
    }

    function isValidGameState(data) {
      return data.keys().hasOnly(['board', 'solution', 'difficulty', 'mistakes', 'timeElapsed']) &&
             data.keys().hasAll(['board', 'solution', 'difficulty', 'mistakes', 'timeElapsed']) &&
             data.board is list && data.board.size() <= 81 &&
             data.solution is list && data.solution.size() <= 81 &&
             data.difficulty is string && data.difficulty.size() <= 20 &&
             data.mistakes is number &&
             data.timeElapsed is number;
    }

    match /users/{userId}/gameState/{docId} {
      allow read: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidGameState(incoming());
      allow update: if isOwner(userId) && isValidId(userId) && isValidGameState(incoming());
      allow delete: if isOwner(userId) && isValidId(userId);
    }
  }
}
