rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    function isValidUserSettings(data) {
      return data.get('theme', '') is string && data.get('theme', '').size() <= 60 &&
             data.get('soundEnabled', true) is bool &&
             data.get('hapticsEnabled', true) is bool &&
             data.get('focusLensEnabled', true) is bool &&
             data.get('stats', {}) is map &&
             (data.get('hapticIntensity', 'medium') in ['low', 'medium', 'high']) &&
             data.keys().hasAll(['theme', 'soundEnabled', 'hapticsEnabled', 'focusLensEnabled', 'stats']) &&
             data.keys().hasOnly(['theme', 'soundEnabled', 'hapticsEnabled', 'hapticIntensity', 'focusLensEnabled', 'stats', 'aiEnabled']);
    }

    match /users/{userId}/settings/{docId} {
      allow read: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUserSettings(incoming());
      allow update: if isOwner(userId) && isValidId(userId) && isValidUserSettings(incoming());
      allow delete: if isOwner(userId) && isValidId(userId);
    }

    function isValidGameState(data) {
      return data.get('version', 2) == 2 &&
             data.get('board', []) is list && data.get('board', []).size() <= 81 &&
             data.get('solution', []) is list && data.get('solution', []).size() <= 81 &&
             data.get('difficulty', '') is string && data.get('difficulty', '').size() <= 20 &&
             data.get('gameKind', '') is string && data.get('gameKind', '').size() <= 20 &&
             data.get('mistakes', 0) is number &&
             data.get('timeElapsed', 0) is number &&
             (data.get('dailyDate', null) == null || (data.get('dailyDate', '') is string && data.get('dailyDate', '').size() <= 20)) &&
             (data.get('dailyDifficulty', null) == null || (data.get('dailyDifficulty', '') is string && data.get('dailyDifficulty', '').size() <= 20)) &&
             (data.get('hintsUsed', 0) is number) &&
             (data.get('currentCombo', 0) is number) &&
             (data.get('maxComboThisGame', 0) is number) &&
             (data.get('lastComboMilestone', null) == null || data.get('lastComboMilestone', 0) is number) &&
             (data.get('completedUnitKeys', []) is list) &&
             (data.get('mistakeShieldState', '') is string && data.get('mistakeShieldState', '').size() <= 20) &&
             data.keys().hasAll(['version', 'board', 'solution', 'difficulty', 'gameKind', 'mistakes', 'timeElapsed']) &&
             data.keys().hasOnly([
               'version', 'board', 'solution', 'difficulty', 'gameKind',
               'dailyDate', 'dailyDifficulty', 'mistakes', 'timeElapsed',
               'hintsUsed', 'currentCombo', 'maxComboThisGame', 'lastComboMilestone',
               'completedUnitKeys', 'mistakeShieldState'
             ]);
    }

    match /users/{userId}/gameState/{docId} {
      allow read: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidGameState(incoming());
      allow update: if isOwner(userId) && isValidId(userId) && isValidGameState(incoming());
      allow delete: if isOwner(userId) && isValidId(userId);
    }
  }
}
