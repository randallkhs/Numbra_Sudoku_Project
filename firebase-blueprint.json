{
  "entities": {
    "UserSettings": {
      "title": "UserSettings",
      "description": "User preferences and settings.",
      "type": "object",
      "properties": {
        "theme": { "type": "string" },
        "soundEnabled": { "type": "boolean" },
        "hapticsEnabled": { "type": "boolean" },
        "hapticIntensity": { "type": "string" },
        "focusLensEnabled": { "type": "boolean" },
        "stats": { "type": "object" }
      }
    },
    "GameState": {
      "title": "GameState",
      "description": "User's current game state.",
      "type": "object",
      "properties": {
        "version": { "type": "number" },
        "board": { "type": "array" },
        "solution": { "type": "array" },
        "difficulty": { "type": "string" },
        "gameKind": { "type": "string" },
        "dailyDate": { "type": "string" },
        "dailyDifficulty": { "type": "string" },
        "mistakes": { "type": "number" },
        "timeElapsed": { "type": "number" },
        "hintsUsed": { "type": "number" },
        "currentCombo": { "type": "number" },
        "maxComboThisGame": { "type": "number" },
        "lastComboMilestone": { "type": "number" },
        "completedUnitKeys": { "type": "array" },
        "mistakeShieldState": { "type": "string" }
      }
    }
  },
  "firestore": {
    "users/{userId}/settings/{docId}": {
      "schema": "UserSettings",
      "description": "Stores user settings"
    },
    "users/{userId}/gameState/{docId}": {
      "schema": "GameState",
      "description": "Stores current game state"
    }
  }
}
